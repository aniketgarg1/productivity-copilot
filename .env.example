GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

BACKEND_URL=http://localhost:8000
SESSION_SECRET=change-this-to-any-random-string
DATABASE_URL=postgresql://postgres:postgres@db:5432/copilot

# Local dev OAuth helpers:
OAUTHLIB_RELAX_TOKEN_SCOPE=1
OAUTHLIB_INSECURE_TRANSPORT=1

# LLM config (users provide their own key)
LLM_PROVIDER=openai
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# Cost-effective defaults (pinned snapshot)
OPENAI_MODEL_MAIN=gpt-4.1-mini-2025-04-14
OPENAI_MODEL_CHEAP=gpt-4.1-nano-2025-04-14